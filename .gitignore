# Ignore all files under log/ and log_human/, but keep directories trackable.
log/**
!log/
!log/**/

log_human/**
!log_human/
!log_human/**/

log_human_2/**
!log_human_2/
!log_human_2/**/

user_log/**
!user_log/
!user_log/**/

# Generic log directories (any level): log*, *_log, *_logs, logs
log*/**
!log*/
!log*/**/

*_log/**
!*_log/
!*_log/**/

*_logs/**
!*_logs/
!*_logs/**/

logs/**
!logs/
!logs/**/

# File locks generated by annotation system
*.json.lock

# LLM config with API keys
config/llm_config.json
config/llm_config_0.json
config/llm_config_1.json
config/llm_config_2.json
config/cpss_eval_config.json

# 辅助翻译模块的 API 配置：屏蔽真实 config，但保留 example.json
translation_config/*
!translation_config/example.json

# Python bytecode / caches
**/__pycache__/
*.py[cod]

model/

# Evaluation / z-score outputs (generated artifacts)
zscore_output/
zscore_output_eval/
